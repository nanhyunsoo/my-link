rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유저 문서 규칙
    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;

      // 링크 서브 컬렉션 규칙
      match /links/{linkId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
