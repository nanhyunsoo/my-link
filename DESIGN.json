{
    "meta": {
        "projectName": "ASALDESIGN Portfolio",
        "designerRef": "Ahmad Fauzi",
        "extractedFrom": "UI portfolio screenshots",
        "version": "1.0.0",
        "theme": "dark-brutalist-minimal"
    },
    "designSystem": {
        "colorPalette": {
            "backgrounds": {
                "pagePrimary": "#0D0D0D",
                "pageTexture": "noise-overlay: url('#grain'), base: #0D0D0D",
                "cardSurface": "#FFFFFF",
                "cardSurfaceDark": "#1A1A1A",
                "badgePillDark": "#1C1C1C",
                "badgePillAccent": "#2A2A2A"
            },
            "typography": {
                "headingPrimary": "#FFFFFF",
                "headingOnCard": "#0D0D0D",
                "bodyOnDark": "#E0E0E0",
                "bodyOnCard": "#333333",
                "labelMuted": "#888888",
                "emailAccent": "#CCCCCC"
            },
            "borders": {
                "buttonOutline": "#FFFFFF",
                "buttonOutlineMuted": "rgba(255,255,255,0.3)",
                "dividerLine": "rgba(255,255,255,0.12)",
                "cardBorder": "transparent"
            },
            "interactive": {
                "buttonActiveBackground": "#FFFFFF",
                "buttonActiveText": "#0D0D0D",
                "buttonDefaultBackground": "transparent",
                "buttonDefaultText": "#FFFFFF",
                "linkHover": "#FFFFFF"
            },
            "projectAccents": {
                "gamingDark": "#1A0A0A",
                "musicPurple": "#7C3AED",
                "musicPurpleLight": "#A78BFA",
                "musicPurpleGradientStart": "#6D28D9",
                "musicPurpleGradientEnd": "#C4B5FD",
                "taskManagementOrange": "#F97316",
                "taskManagementGreen": "#22C55E",
                "realEstateBlue": "#3B82F6"
            },
            "badgeLabels": {
                "firstPlace": {
                    "background": "#1C1C1C",
                    "text": "#FFFFFF",
                    "border": "#333333"
                },
                "thirdPlace": {
                    "background": "#1C1C1C",
                    "text": "#FFFFFF",
                    "border": "#333333"
                },
                "designChallenge": {
                    "background": "#1C1C1C",
                    "text": "#FFFFFF",
                    "border": "#333333"
                }
            }
        },
        "typography": {
            "fontFamilies": {
                "display": "'Neue Haas Grotesk', 'Helvetica Neue', 'Arial Black', sans-serif",
                "body": "'Helvetica Neue', 'Inter', sans-serif",
                "note": "Primary display font is an ultra-bold grotesque. Nearest web equivalent: 'Syne', 'DM Sans Bold', or 'Barlow Condensed Black'."
            },
            "scale": {
                "heroTitle": {
                    "size": "clamp(64px, 12vw, 128px)",
                    "weight": 900,
                    "lineHeight": 0.9,
                    "letterSpacing": "-0.02em",
                    "transform": "uppercase",
                    "color": "#FFFFFF",
                    "usage": "Main brand/name display — ASALDESIGN, GET IN TOUCH"
                },
                "sectionHeading": {
                    "size": "clamp(32px, 5vw, 56px)",
                    "weight": 800,
                    "lineHeight": 1.0,
                    "letterSpacing": "-0.01em",
                    "transform": "uppercase",
                    "color": "#FFFFFF",
                    "usage": "FEATURED PROJECTS, ACHIEVEMENT"
                },
                "cardHeading": {
                    "size": "20px",
                    "weight": 700,
                    "lineHeight": 1.2,
                    "transform": "uppercase",
                    "color": "#0D0D0D",
                    "usage": "Achievement card titles"
                },
                "heroSubtitle": {
                    "size": "clamp(11px, 1.4vw, 15px)",
                    "weight": 500,
                    "lineHeight": 1.6,
                    "letterSpacing": "0.04em",
                    "transform": "uppercase",
                    "color": "#DDDDDD",
                    "usage": "Hero tagline below main title"
                },
                "bodySmall": {
                    "size": "12px",
                    "weight": 400,
                    "lineHeight": 1.6,
                    "color": "#AAAAAA",
                    "usage": "Bio columns, project descriptions, footer links"
                },
                "bodyCard": {
                    "size": "12px",
                    "weight": 400,
                    "lineHeight": 1.5,
                    "color": "#555555",
                    "usage": "Description text inside white achievement/project cards"
                },
                "navLabel": {
                    "size": "11px",
                    "weight": 400,
                    "lineHeight": 1.4,
                    "letterSpacing": "0.01em",
                    "color": "#FFFFFF",
                    "usage": "Navigation bar top — role, name, brand label"
                },
                "viewLink": {
                    "size": "12px",
                    "weight": 500,
                    "color": "#0D0D0D",
                    "textDecoration": "none",
                    "usage": "'View Full Here' and 'View Design' CTAs on project/achievement cards"
                }
            }
        },
        "spacing": {
            "base": "8px",
            "scale": {
                "xs": "4px",
                "sm": "8px",
                "md": "16px",
                "lg": "24px",
                "xl": "40px",
                "xxl": "64px",
                "xxxl": "96px",
                "section": "120px"
            },
            "layout": {
                "pageHorizontalPadding": "clamp(24px, 6vw, 80px)",
                "navHeight": "56px",
                "heroPaddingTop": "80px",
                "sectionGap": "80px",
                "cardGridGap": "20px"
            }
        },
        "borderRadius": {
            "none": "0px",
            "pill": "9999px",
            "button": "9999px",
            "badge": "9999px",
            "card": "16px",
            "cardLarge": "20px",
            "imageThumb": "12px"
        },
        "shadows": {
            "card": "0 4px 24px rgba(0,0,0,0.15)",
            "cardHover": "0 8px 40px rgba(0,0,0,0.25)",
            "buttonActive": "0 0 0 2px rgba(255,255,255,0.4)",
            "none": "none"
        },
        "components": {
            "navbar": {
                "background": "transparent",
                "position": "sticky",
                "height": "56px",
                "paddingInline": "clamp(24px, 6vw, 80px)",
                "layout": "3-column flex: left(role), center(name), right(brandname)",
                "borderBottom": "1px solid rgba(255,255,255,0.12)",
                "typography": "navLabel",
                "divider": {
                    "style": "solid",
                    "color": "rgba(255,255,255,0.12)",
                    "thickness": "1px"
                }
            },
            "heroSection": {
                "background": "#0D0D0D",
                "backgroundEffect": "subtle grain/noise texture overlay",
                "layout": "center-aligned vertical stack",
                "elements": {
                    "logoIcon": {
                        "type": "SVG owl/glasses icon",
                        "size": "40px",
                        "color": "#FFFFFF",
                        "marginBottom": "16px"
                    },
                    "title": {
                        "typography": "heroTitle",
                        "marginBottom": "24px"
                    },
                    "subtitle": {
                        "typography": "heroSubtitle",
                        "maxWidth": "600px",
                        "marginBottom": "32px"
                    },
                    "bioColumns": {
                        "layout": "3-column horizontal flex",
                        "gap": "32px",
                        "borderTop": "1px solid rgba(255,255,255,0.12)",
                        "paddingTop": "24px",
                        "typography": "bodySmall"
                    },
                    "ctaButtons": {
                        "layout": "horizontal flex, gap 12px",
                        "marginTop": "40px"
                    }
                }
            },
            "buttons": {
                "pilOutline": {
                    "background": "transparent",
                    "border": "1.5px solid #FFFFFF",
                    "borderRadius": "9999px",
                    "paddingInline": "28px",
                    "paddingBlock": "12px",
                    "color": "#FFFFFF",
                    "typography": {
                        "size": "13px",
                        "weight": 600,
                        "letterSpacing": "0.06em",
                        "transform": "uppercase"
                    },
                    "hover": {
                        "background": "#FFFFFF",
                        "color": "#0D0D0D"
                    },
                    "transition": "all 0.2s ease"
                },
                "pillSolid": {
                    "background": "#FFFFFF",
                    "border": "1.5px solid #FFFFFF",
                    "borderRadius": "9999px",
                    "paddingInline": "28px",
                    "paddingBlock": "12px",
                    "color": "#0D0D0D",
                    "typography": {
                        "size": "13px",
                        "weight": 600,
                        "letterSpacing": "0.06em",
                        "transform": "uppercase"
                    },
                    "usage": "Active tab, Contact Me CTA"
                },
                "tabActive": {
                    "background": "#FFFFFF",
                    "borderRadius": "9999px",
                    "paddingInline": "20px",
                    "paddingBlock": "8px",
                    "color": "#0D0D0D",
                    "typography": {
                        "size": "13px",
                        "weight": 600
                    }
                },
                "tabInactive": {
                    "background": "transparent",
                    "borderRadius": "9999px",
                    "paddingInline": "20px",
                    "paddingBlock": "8px",
                    "color": "#FFFFFF",
                    "typography": {
                        "size": "13px",
                        "weight": 500
                    }
                },
                "cardCTA": {
                    "background": "#0D0D0D",
                    "borderRadius": "9999px",
                    "paddingInline": "16px",
                    "paddingBlock": "8px",
                    "color": "#FFFFFF",
                    "typography": {
                        "size": "11px",
                        "weight": 500
                    },
                    "usage": "'View Design' button inside achievement cards"
                },
                "seeMore": {
                    "background": "#FFFFFF",
                    "borderRadius": "9999px",
                    "paddingInline": "32px",
                    "paddingBlock": "14px",
                    "color": "#0D0D0D",
                    "typography": {
                        "size": "14px",
                        "weight": 600
                    },
                    "boxShadow": "0 2px 12px rgba(0,0,0,0.15)",
                    "usage": "See More CTA below project cards"
                }
            },
            "projectCard": {
                "background": "#FFFFFF",
                "borderRadius": "20px",
                "padding": "0",
                "overflow": "hidden",
                "shadow": "0 4px 24px rgba(0,0,0,0.12)",
                "imageArea": {
                    "background": "varies by project (dark for gaming, purple gradient for music, blue for real estate)",
                    "height": "200px",
                    "overflow": "hidden",
                    "borderRadius": "16px 16px 0 0"
                },
                "contentArea": {
                    "padding": "16px",
                    "background": "#FFFFFF"
                },
                "projectTitle": {
                    "typography": {
                        "size": "15px",
                        "weight": 700,
                        "color": "#0D0D0D"
                    }
                },
                "projectDescription": {
                    "typography": {
                        "size": "12px",
                        "weight": 400,
                        "color": "#666666"
                    }
                },
                "viewLink": {
                    "typography": {
                        "size": "12px",
                        "weight": 500,
                        "color": "#0D0D0D"
                    },
                    "display": "flex",
                    "alignItems": "center",
                    "gap": "4px",
                    "arrowIcon": "→ or ↗"
                },
                "gridLayout": "2-column, equal width, gap: 20px"
            },
            "achievementCard": {
                "background": "#FFFFFF",
                "borderRadius": "16px",
                "padding": "20px",
                "shadow": "0 2px 16px rgba(0,0,0,0.10)",
                "badgeRow": {
                    "display": "flex",
                    "gap": "8px",
                    "marginBottom": "12px"
                },
                "badge": {
                    "placementBadge": {
                        "background": "#0D0D0D",
                        "color": "#FFFFFF",
                        "borderRadius": "9999px",
                        "paddingInline": "10px",
                        "paddingBlock": "4px",
                        "fontSize": "10px",
                        "fontWeight": 600,
                        "examples": [
                            "1st Place",
                            "3rd Place"
                        ]
                    },
                    "categoryBadge": {
                        "background": "#EFEFEF",
                        "color": "#333333",
                        "borderRadius": "9999px",
                        "paddingInline": "10px",
                        "paddingBlock": "4px",
                        "fontSize": "10px",
                        "fontWeight": 500,
                        "examples": [
                            "Design Challenge"
                        ]
                    }
                },
                "title": {
                    "size": "18px",
                    "weight": 800,
                    "color": "#0D0D0D",
                    "transform": "uppercase",
                    "marginBottom": "8px"
                },
                "description": {
                    "size": "11px",
                    "weight": 400,
                    "color": "#666666",
                    "marginBottom": "16px"
                },
                "gridLayout": "2-column slider/carousel, gap: 20px",
                "carouselNav": {
                    "arrows": "< >",
                    "color": "#FFFFFF",
                    "position": "below cards, left-aligned"
                }
            },
            "footerSection": {
                "background": "#0D0D0D",
                "paddingBlock": "64px",
                "layout": "center-aligned",
                "heroText": {
                    "typography": "heroTitle",
                    "text": "GET IN TOUCH",
                    "marginBottom": "16px"
                },
                "subtext": {
                    "typography": {
                        "size": "12px",
                        "weight": 400,
                        "color": "#AAAAAA",
                        "transform": "uppercase",
                        "letterSpacing": "0.04em"
                    }
                },
                "footerLinks": {
                    "display": "flex",
                    "gap": "32px",
                    "justifyContent": "center",
                    "marginTop": "24px",
                    "typography": {
                        "size": "11px",
                        "weight": 500,
                        "color": "#888888",
                        "transform": "uppercase",
                        "letterSpacing": "0.06em"
                    },
                    "label": "FOLLOW ALL MY ACCOUNTS:"
                }
            }
        },
        "effects": {
            "backgroundTexture": {
                "type": "grain/noise",
                "implementation": "SVG feTurbulence filter or CSS noise overlay",
                "opacity": 0.04,
                "blendMode": "overlay",
                "usage": "Applied to full-page dark background sections"
            },
            "transitions": {
                "default": "all 0.2s ease",
                "hover": "background 0.2s ease, color 0.2s ease, transform 0.15s ease",
                "cardHover": "transform 0.2s ease, box-shadow 0.2s ease"
            },
            "hoverStates": {
                "pillButton": {
                    "background": "#FFFFFF",
                    "color": "#0D0D0D"
                },
                "projectCard": {
                    "transform": "translateY(-4px)",
                    "boxShadow": "0 8px 40px rgba(0,0,0,0.20)"
                },
                "viewLink": {
                    "textDecoration": "underline"
                }
            }
        },
        "layout": {
            "maxWidth": "1200px",
            "gridSystem": "12-column, gap: 24px",
            "breakpoints": {
                "mobile": "< 640px",
                "tablet": "640px – 1024px",
                "desktop": "> 1024px"
            },
            "sections": [
                {
                    "id": "navbar",
                    "position": "sticky top"
                },
                {
                    "id": "hero",
                    "layout": "centered column, full-width dark"
                },
                {
                    "id": "featured-projects",
                    "layout": "2-col grid with tab filter"
                },
                {
                    "id": "achievement",
                    "layout": "2-col card carousel"
                },
                {
                    "id": "get-in-touch",
                    "layout": "centered CTA, full-width dark"
                },
                {
                    "id": "footer-links",
                    "layout": "centered horizontal links"
                }
            ]
        },
        "iconography": {
            "brandIcon": {
                "type": "Owl/glasses SVG",
                "size": "40px",
                "color": "#FFFFFF",
                "position": "above hero title, centered"
            },
            "arrows": {
                "carouselLeft": "‹",
                "carouselRight": "›",
                "viewLink": "↗ or →",
                "color": "#FFFFFF on dark, #0D0D0D on light"
            },
            "socialLinks": {
                "platforms": [
                    "Dribbble",
                    "Instagram",
                    "LinkedIn",
                    "Figma Community",
                    "Medium",
                    "TDThinker"
                ],
                "style": "pill outline buttons (desktop) / plain text links (footer)"
            }
        }
    },
    "implementationNotes": {
        "fontRecommendation": "Load 'Syne' (900 weight) from Google Fonts for hero display. Fallback: 'Helvetica Neue', 'Arial Black'.",
        "grainTextureCSS": "Use filter: url(#grain) with SVG feTurbulence, or background-image: url(data:image/svg+xml...) repeating noise pattern.",
        "colorConsistency": "All dark sections use #0D0D0D base. White cards (#FFFFFF) appear on dark sections only — never nest dark cards inside dark sections.",
        "avoidCommonErrors": [
            "Do NOT apply card border-radius to inner image thumbnails separately — use overflow:hidden on the parent card",
            "Do NOT use the hero title font size for body copy",
            "Do NOT add drop shadows to text — shadows only on card containers",
            "Do NOT use purple gradients unless for music/creative project card backgrounds specifically",
            "Ensure all pill buttons have equal padding — they should feel balanced, not text-tight"
        ],
        "accessibilityNotes": {
            "contrastHeroBg": "White #FFFFFF on #0D0D0D = 19.5:1 ✅",
            "contrastCardText": "#0D0D0D on #FFFFFF = 19.5:1 ✅",
            "contrastBodyMuted": "#AAAAAA on #0D0D0D = ~5.2:1 ✅ (AA large text)",
            "focusStates": "Add visible focus ring: outline: 2px solid #FFFFFF, outline-offset: 3px"
        }
    }
}